# Django Security configuration
SECRET_KEY=generate-a-random-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (Neon/Supabase in production, local SQLite if empty)
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# Redis Broker Configuration
# Used by Celery for dispatching background tasks (e.g. generating and rendering PDF ticket boarding passes)
REDIS_URL=redis://localhost:6379/0

# Cors allowed origins for React frontend (Vercel origin in production)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# API Access tokens / Webhooks
# Checked by backend as 'CRON_SECRET' or 'INVENTORY_API_TOKEN' to authenticate 
# daily automated bus generation webhooks from GitHub Action CRON jobs.
INVENTORY_API_TOKEN=generate-a-long-random-string
CRON_SECRET=generate-a-long-random-string
